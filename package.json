{
  "name": "wasifbinnasir",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run postbuild",
    "postbuild": "npm run sitemap",
    "start": "next start",
    "lint": "next lint",
    "sitemap": "cross-env NODE_OPTIONS='--experimental-json-modules' node ./src/scripts/generateSitemap.mjs",
    "analyze": "cross-env ANALYZE=true next build",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,mdx,css,json}\"",
    "format:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx,mdx,css,json}\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@tailwindcss/forms": "^0.5.11",
    "formik": "^2.4.9",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "lru-cache": "^11.3.5",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "next-seo": "^7.2.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "autoprefixer": "10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globby": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "4.2.3",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}
